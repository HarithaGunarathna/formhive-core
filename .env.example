# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/formhive

# Redis
REDIS_URL=redis://localhost:6379

# Node
NODE_ENV=development

# apps/api
PORT=3000
JWT_SECRET=change-me-before-production

# apps/form
FORM_PORT=3001
FORM_BASE_URL=http://localhost:3001

# Integration tests — set after running pnpm db:seed
# This must be the plaintext key whose bcrypt hash is stored in tenants.api_key_hash
# for the seed tenant (id = '00000000-0000-0000-0000-000000000001')
SEED_API_KEY=

# apps/notification — SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=

# apps/notification — stubs (Phase 1: logs to console instead of calling real APIs)
WHATSAPP_API_URL=stub
SMS_API_URL=stub
